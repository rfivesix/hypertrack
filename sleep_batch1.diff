+    expect(byStatus.length, 1);
+    expect(byHash.length, 1);
+    expect(byRange.length, 1);
+    expect(byRange.single.payloadJson, '{"sample":true}');
+  });
+
+  test('canonical daos insert/query and delete-by-range semantics work', () async {
