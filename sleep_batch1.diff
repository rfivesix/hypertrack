+    await rawDao.upsert(
+      SleepRawImportCompanion(
+        id: 'raw-1',
+        sourcePlatform: 'health_connect',
+        sourceAppId: 'com.android.healthconnect',
+        sourceConfidence: 'medium',
+        sourceRecordHash: 'hash-raw-for-session-1',
+        importStatus: 'success',
