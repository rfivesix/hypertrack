<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="25dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/today_focus_widget_row_accent"
        android:layout_width="4dp"
        android:layout_height="20dp"
        android:contentDescription="@null"
        android:background="#FF4CAF50" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/today_focus_widget_row_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/today_focus_widget_text_secondary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/today_focus_widget_row_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/today_focus_widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
